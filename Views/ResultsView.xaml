<UserControl x:Class="SqlStressRunner.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SqlStressRunner.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Test Results" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Run ID:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RunIdText}" Margin="5"/>
                    <Button Grid.Row="0" Grid.Column="2" 
                            Content="📋 Copy" 
                            Command="{Binding CopyRunIdCommand}"
                            ToolTip="Copy Run ID to clipboard"
                            Padding="8,4"
                            Margin="5,0"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Total Duration:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding TotalDurationText}" Margin="5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Iterations:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalIterationsText}" Margin="5" Grid.ColumnSpan="2"/>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Successful:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding SuccessfulIterationsText}" Foreground="Green" Margin="5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Failed:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FailedIterationsText}" Foreground="Red" Margin="5" Grid.ColumnSpan="2"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="TPS (Iteration):" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding TpsPerIterationText}" Margin="5" FontWeight="Bold" FontSize="14"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="TPS (Per SP):" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TpsPerSpText}" Margin="5" FontWeight="Bold" FontSize="14" Grid.ColumnSpan="2"/>

                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Avg Latency:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding AverageLatencyText}" Margin="5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Min Latency:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MinLatencyText}" Margin="5" Grid.ColumnSpan="2"/>

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Max Latency:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding MaxLatencyText}" Margin="5"/>
                </Grid>
            </Border>

            <TextBlock Text="Latency Percentiles" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="P95:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Column="1" Text="{Binding P95LatencyText}" Margin="5"/>

                    <TextBlock Grid.Column="2" Text="P99:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Column="3" Text="{Binding P99LatencyText}" Margin="5"/>
                </Grid>
            </Border>

            <TextBlock Text="Stored Procedure Performance" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
            <Border BorderBrush="Gray" BorderThickness="1" Padding="15">
                <DataGrid ItemsSource="{Binding StoredProcedureMetrics}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          MinHeight="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Stored Procedure" Binding="{Binding StoredProcedureName}" Width="*"/>
                        <DataGridTextColumn Header="Average Duration (ms)" Binding="{Binding AverageDurationMs, StringFormat={}{0:F2}}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
