<UserControl x:Class="SqlStressRunner.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SqlStressRunner.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Database Connection Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <CheckBox Grid.Row="2" Grid.Column="1" Content="Use Integrated Security (Windows Authentication)" 
                          IsChecked="{Binding UseIntegratedSecurity}" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         IsEnabled="{Binding UseIntegratedSecurity, Converter={StaticResource InverseBoolConverter}}" Margin="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,5"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox"
                             IsEnabled="{Binding UseIntegratedSecurity, Converter={StaticResource InverseBoolConverter}}" 
                             Margin="5" PasswordChanged="PasswordBox_PasswordChanged"/>

                <CheckBox Grid.Row="5" Grid.Column="1" Content="Trust Server Certificate" 
                          IsChecked="{Binding TrustServerCertificate}" Margin="5"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Connection Timeout:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ConnectionTimeout, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="5,20,5,5">
                    <Button Content="Test Connection" Command="{Binding TestConnectionCommand}" Padding="15,5" Margin="0,0,10,0"/>
                    <Button Content="Setup Database" Command="{Binding SetupDatabaseCommand}" Padding="15,5" Margin="0,0,10,0"/>
                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Padding="15,5"/>
                </StackPanel>

                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding StatusMessage}" 
                           Foreground="Blue" Margin="5" TextWrapping="Wrap"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
