<UserControl x:Class="SqlStressRunner.Views.TestConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SqlStressRunner.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Test Configuration" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Initial Query (Load Test Data):" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBox Text="{Binding InitialQuery, UpdateSourceTrigger=PropertyChanged}" 
                     Height="100" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                     FontFamily="Consolas" Margin="0,0,0,10"/>

            <!-- Stored Procedures Section -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,10,0,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Stored Procedures:" FontWeight="Bold" FontSize="14" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="+ Add SP" Command="{Binding AddStoredProcedureCommand}" 
                                Padding="10,5" Margin="10,0,0,0" DockPanel.Dock="Right"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding StoredProcedures}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Header Row -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,5">
                                            <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="80" Margin="0,0,10,0"/>
                                            <TextBlock Text="(Order:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="{Binding Order}" VerticalAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Text=")" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="↑" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Width="30" Margin="2"/>
                                            <Button Content="↓" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Width="30" Margin="2"/>
                                            <Button Content="✖" Command="{Binding DataContext.RemoveStoredProcedureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Width="30" Margin="2" Foreground="Red"/>
                                        </StackPanel>

                                        <!-- SQL Command Row -->
                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                                                 Text="{Binding SqlCommand, UpdateSourceTrigger=PropertyChanged}" 
                                                 Height="60" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                                 FontFamily="Consolas" Margin="0,5,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Command Timeout (sec):" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CommandTimeout, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Max Parallelism:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MaxDegreeOfParallelism, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Iterations:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TotalIterations, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="Recycle Dataset" 
                          IsChecked="{Binding RecycleDataset}" Margin="5" VerticalAlignment="Center"/>

                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Log Results to Database" 
                          IsChecked="{Binding LogToDatabase}" Margin="0,5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Log Table Name:" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" 
                         Text="{Binding LogTableName, UpdateSourceTrigger=PropertyChanged}" 
                         IsEnabled="{Binding LogToDatabase}" Margin="5"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,10">
                <Button Content="Load Initial Data" Command="{Binding LoadInitialDataCommand}" 
                        Padding="15,5" Margin="0,0,10,0"/>
                <Button Content="Start Test" Command="{Binding StartTestCommand}" 
                        Padding="15,5" Margin="0,0,10,0" Background="Green" Foreground="White"/>
                <Button Content="Cancel Test" Command="{Binding CancelTestCommand}" 
                        Padding="15,5" Background="Red" Foreground="White"/>
            </StackPanel>

            <ProgressBar Height="25" Value="{Binding ProgressPercentage, Mode=OneWay}" 
                         Minimum="0" Maximum="100" Margin="0,10"/>

            <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" 
                       Margin="0,5" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
